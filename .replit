modules = ["nodejs-24", "python-3.12"]
run = "cd artifacts/cve-risk-prioritizer && streamlit run app.py --server.port=${PORT:-5000} --server.address=0.0.0.0"

[deployment]
router = "application"
deploymentTarget = "autoscale"
healthCheckPath = "/_stcore/health"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
